# ============================================
# 必需配置
# ============================================

# DeepSeek API 密钥（从 https://platform.deepseek.com/ 获取）
QUERY_DEEPSEEK_API_KEY=your_api_key_here

# 管理员 QQ 号列表（逗号分隔，用于状态控制插件身份验证）
QUERY_ADMIN_USER_IDS=123456789,987654321

# ============================================
# 功能开关（可选，默认全部开启）
# ============================================
QUERY_MATH_ENABLED=True
QUERY_RANDOM_ENABLED=True
QUERY_HIGHNOON_ENABLED=True
QUERY_PJSKPARTTION_ENABLED=True
QUERY_MATH_SOUP_ENABLED=True
QUERY_ECHO_ENABLED=True
QUERY_MCMOD_SEARCH_ENABLED=True
QUERY_MCMOD_CAPTURE_SELECTORS=class-title,class-text-top

# ============================================
# DeepSeek API 配置（可选）
# ============================================
QUERY_DEEPSEEK_BASE_URL=https://api.deepseek.com
QUERY_DEEPSEEK_MODEL=deepseek-chat

# ============================================
# AI 参数配置 - 数学定义（可选）
# ============================================
QUERY_MATH_TEMPERATURE=0.3
QUERY_MATH_MAX_TOKENS=512
QUERY_MATH_TOP_P=0.8

# ============================================
# AI 参数配置 - 随机回复（可选）
# ============================================
QUERY_RANDOM_TEMPERATURE=0.8
QUERY_RANDOM_MAX_TOKENS_MIN=30
QUERY_RANDOM_MAX_TOKENS_MAX=100
QUERY_RANDOM_TOP_P=0.95

# ============================================
# 复读配置（可选）
# ============================================
QUERY_ECHO_PROBABILITY=0.01
QUERY_ECHO_REVERSE_PROBABILITY=0.2

# ============================================
# 其他配置（可选）
# ============================================
QUERY_DATA_DIR=data
QUERY_MAX_HISTORY_PER_GROUP=50
QUERY_MAX_BAN_PER_GROUP=10

# 消息发送缓冲间隔（毫秒，默认 800ms，用于防风控，可根据需要调整）
QUERY_BUFFER_INTERVAL_MS=800
